@model JiujitsuGymApp.Models.HomeViewModel?

@{
    ViewData["Title"] = "Home";
    var isAuthenticated = User.Identity?.IsAuthenticated ?? false;
}

@if (!isAuthenticated)
{
    <!-- ── Landing hero for guests ── -->
    <div class="py-5 text-center">
        <i class="fas fa-dumbbell fa-3x text-primary mb-3"></i>
        <h1 class="display-5 fw-bold">Welcome to Jiujitsu Gym</h1>
        <p class="lead text-muted col-md-7 mx-auto">
            Track your progress, manage your classes, and train your way to black belt.
        </p>
        <div class="d-flex gap-3 justify-content-center mt-4">
            <a asp-controller="Account" asp-action="Register" class="btn btn-primary btn-lg">
                <i class="fas fa-user-plus me-2"></i>Get Started
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn btn-outline-secondary btn-lg">
                <i class="fas fa-sign-in-alt me-2"></i>Login
            </a>
        </div>
    </div>

    <hr class="my-5" />

    <!-- ── Feature highlights ── -->
    <div class="row g-4 text-center mb-5">
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <i class="fas fa-calendar-check fa-2x text-primary mb-3"></i>
                <h5 class="fw-bold">Class Scheduling</h5>
                <p class="text-muted">View the weekly class calendar and check in to sessions in one click.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <i class="fas fa-chart-line fa-2x text-primary mb-3"></i>
                <h5 class="fw-bold">Belt Progression</h5>
                <p class="text-muted">Track every class attended and watch your progress toward the next belt.</p>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border-0 shadow-sm p-4">
                <i class="fas fa-shopping-bag fa-2x text-primary mb-3"></i>
                <h5 class="fw-bold">Gym Store</h5>
                <p class="text-muted">Browse and purchase gear from the gym's product catalogue.</p>
            </div>
        </div>
    </div>
}
else if (Model is not null)
{
    <!-- ── Authenticated dashboard ── -->

    <!-- Greeting hero -->
    <div class="p-4 mb-4 rounded-3 border" style="background: linear-gradient(135deg, #667eea22, #764ba211);">
        <div class="d-flex align-items-center gap-3">
            <div class="rounded-circle d-flex align-items-center justify-content-center text-white fw-bold fs-4"
                 style="width:56px;height:56px;background:linear-gradient(135deg,#667eea,#764ba2);flex-shrink:0;">
                @Model.FirstName[0]
            </div>
            <div>
                <h2 class="mb-0 fw-bold">Welcome back, @Model.FirstName!</h2>
                <span class="text-muted">@Model.Belt Belt · @Model.TotalClassesAttended classes attended</span>
            </div>
        </div>
    </div>

    <div class="row g-4">

        <!-- Belt progression -->
        <div class="col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <h6 class="fw-bold text-uppercase text-muted small mb-3">
                        <i class="fas fa-chart-line me-1"></i>Belt Progression
                    </h6>
                    <profile-progression
                        belt="@Model.Belt"
                        attendance-count="@Model.TotalClassesAttended">
                    </profile-progression>
                </div>
            </div>
        </div>

        <!-- Today's classes -->
        <div class="col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="fw-bold text-uppercase text-muted small mb-0">
                            <i class="fas fa-calendar-day me-1"></i>Today's Classes
                        </h6>
                        <a asp-controller="Classes" asp-action="Index" class="btn btn-sm btn-outline-primary">
                            Full calendar
                        </a>
                    </div>

                    @if (!Model.TodayClasses.Any())
                    {
                        <p class="text-muted mb-0">No classes scheduled for today.</p>
                    }
                    else
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var c in Model.TodayClasses)
                            {
                                var time = DateTime.Parse(c.DateTime).ToLocalTime().ToString("h:mm tt");
                                <div class="list-group-item px-0 d-flex justify-content-between align-items-center">
                                    <div>
                                        <span class="fw-semibold">@time</span>
                                        <span class="text-muted ms-2">@c.Location</span>
                                        <div class="small text-muted">
                                            <i class="fas fa-user me-1"></i>@c.TeacherName
                                            <span class="ms-2">
                                                <i class="fas fa-users me-1"></i>@c.AttendanceCount
                                            </span>
                                        </div>
                                    </div>
                                    @if (c.CheckedIn)
                                    {
                                        <span class="badge bg-success">
                                            <i class="fas fa-check me-1"></i>Checked in
                                        </span>
                                    }
                                    else
                                    {
                                        <a asp-controller="Classes" asp-action="Index"
                                           class="btn btn-sm btn-outline-primary">
                                            Check in
                                        </a>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>

    </div>

    <!-- Quick actions -->
    <div class="row g-3 mt-2">
        <div class="col-6 col-md-3">
            <a asp-controller="Profile" asp-action="Index"
               class="card border-0 shadow-sm text-center p-3 text-decoration-none text-dark d-block">
                <i class="fas fa-user fa-lg text-primary mb-2 d-block"></i>
                <span class="small fw-semibold">My Profile</span>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Classes" asp-action="Index"
               class="card border-0 shadow-sm text-center p-3 text-decoration-none text-dark d-block">
                <i class="fas fa-calendar-alt fa-lg text-primary mb-2 d-block"></i>
                <span class="small fw-semibold">Classes</span>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Products" asp-action="Index"
               class="card border-0 shadow-sm text-center p-3 text-decoration-none text-dark d-block">
                <i class="fas fa-shopping-bag fa-lg text-primary mb-2 d-block"></i>
                <span class="small fw-semibold">Store</span>
            </a>
        </div>
        <div class="col-6 col-md-3">
            <a asp-controller="Profile" asp-action="Edit"
               class="card border-0 shadow-sm text-center p-3 text-decoration-none text-dark d-block">
                <i class="fas fa-pen fa-lg text-primary mb-2 d-block"></i>
                <span class="small fw-semibold">Edit Profile</span>
            </a>
        </div>
    </div>
}
